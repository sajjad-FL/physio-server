MONGODB_URI=mongodb://localhost:27017/syco

# SPA origin for /api/seo/physio-sitemap.xml <loc> entries (no trailing slash). Must match the live marketing site.
# Production: https://nearbyphysio.com — Local: http://localhost:5173
PUBLIC_CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change_me
# Default gross amount (₹) for marketplace bookings before a physio is assigned (Razorpay order amount).
DEFAULT_BOOKING_AMOUNT_RUPEES=500
# When true: forgot-password and POST /auth/signup-otp return OTP in JSON + console; enables debug login. Needed for local signup until SMS is integrated.
DEBUG_OTP=false
